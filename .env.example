# Copy to .env and adjust. Every value here already has a sane default.

# ---- Ports on the host --------------------------------------------------
GATEWAY_PORT=8600
POCKET_PORT=8601
KOKORO_PORT=8880
CHATTERBOX_PORT=4123

# ---- PocketTTS ----------------------------------------------------------
# english | german | italian | portuguese | spanish  (12 layers, ~3x realtime)
# french_24l | german_24l | italian_24l | portuguese_24l | spanish_24l
#   (24 layers, better prosody, ~1x realtime on this CPU)
POCKET_LANGUAGE=spanish
# Built-in voice matching the language above (lola=es, giovanni=it, alba=en...)
POCKET_VOICE=lola
# int8 quantization: faster and lighter, slightly lower quality
POCKET_QUANTIZE=false
# CPU threads per generation. Pocket TTS needs ~2 to run faster than realtime.
POCKET_THREADS=4

# ---- Chatterbox ---------------------------------------------------------
# gpu | latest-cpu   (use latest-cpu if you would rather keep the GPU free)
CHATTERBOX_TAG=gpu
# cuda | cpu  — must match the tag above
CHATTERBOX_DEVICE=cuda
# 0.0-2.0, how much emotion to inject
CHATTERBOX_EXAGGERATION=0.5
CHATTERBOX_CFG_WEIGHT=0.5
CHATTERBOX_TEMPERATURE=0.8

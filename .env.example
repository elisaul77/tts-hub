# Copy to .env and adjust. Every value here already has a sane default.

# ---- Ports on the host --------------------------------------------------
GATEWAY_PORT=8600
POCKET_PORT=8601
STT_PORT=8602
KOKORO_PORT=8880
CHATTERBOX_PORT=4123

# ---- Conversation loop --------------------------------------------------
# Any OpenAI-compatible server. LM Studio must have "Serve on local network"
# enabled, otherwise it only listens on 127.0.0.1 and the container cannot
# reach it. For Ollama use http://host.docker.internal:11434/v1 and start it
# with OLLAMA_HOST=0.0.0.0.
LLM_URL=http://host.docker.internal:1234/v1
# Empty = use whichever model the server has loaded
LLM_MODEL=
LLM_API_KEY=not-needed
# SYSTEM_PROMPT=Eres un asistente de voz. Responde en español, breve y natural.

# ---- Speech to text (faster-whisper) ------------------------------------
# tiny | base | small | medium | large-v3
STT_MODEL=small
# cpu | cuda  (cuda needs a CUDA base image, see README)
STT_DEVICE=cpu
# int8 for CPU, float16 for GPU
STT_COMPUTE_TYPE=int8
# Fixed language beats auto-detection on short utterances. Empty = auto.
STT_LANGUAGE=es
STT_THREADS=4

# ---- PocketTTS ----------------------------------------------------------
# english | german | italian | portuguese | spanish  (12 layers, ~3x realtime)
# french_24l | german_24l | italian_24l | portuguese_24l | spanish_24l
#   (24 layers, better prosody, ~1x realtime on this CPU)
POCKET_LANGUAGE=spanish
# Built-in voice matching the language above (lola=es, giovanni=it, alba=en...)
POCKET_VOICE=lola
# int8 quantization: faster and lighter, slightly lower quality
POCKET_QUANTIZE=false
# CPU threads per generation. Pocket TTS needs ~2 to run faster than realtime.
POCKET_THREADS=4

# ---- Chatterbox ---------------------------------------------------------
# gpu | latest-cpu   (use latest-cpu if you would rather keep the GPU free)
CHATTERBOX_TAG=gpu
# cuda | cpu  — must match the tag above
CHATTERBOX_DEVICE=cuda
# 0.0-2.0, how much emotion to inject
CHATTERBOX_EXAGGERATION=0.5
CHATTERBOX_CFG_WEIGHT=0.5
CHATTERBOX_TEMPERATURE=0.8
